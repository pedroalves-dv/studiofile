# Shopify Store Configuration
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
NEXT_PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN=your_storefront_access_token_here
SHOPIFY_STOREFRONT_PRIVATE_TOKEN=  # Server-only private token for authenticated storefront queries

# Site Configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000  # Production: https://studiofile.vercel.app

# Optional: Analytics
# NEXT_PUBLIC_GA_ID=
