# Shopify Store Configuration
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
NEXT_PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN=your_storefront_access_token_here

# Site Configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: Analytics
# NEXT_PUBLIC_GA_ID=

# Shopify Admin API token (server-side only — never prefix with NEXT_PUBLIC_)
# Required scopes: write_draft_orders, read_products
# Create at: Shopify Admin > Settings > Apps and sales channels > Develop apps > Create an app
SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxx
